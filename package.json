{
  "name": "cet-exam-system",
  "private": true,
  "type": "module",
  "scripts": {
    "content:build": "tsx scripts/build-content-index.ts",
    "build": "react-router build",
    "cf-typegen": "wrangler types",
    "cloudflare:bootstrap": "node scripts/cloudflare-bootstrap.mjs",
    "cloudflare:login": "wrangler login",
    "check": "npm run build && wrangler deploy --dry-run",
    "dev": "react-router dev",
    "deploy": "npm run build && wrangler deploy",
    "prebuild": "npm run content:build",
    "predev": "npm run content:build",
    "preview": "npm run build && vite preview",
    "postinstall": "npm run cf-typegen",
